# =============================================
# Phishing Detector - Environment Variables
# =============================================

# Flask Secret Key (change this!)
SECRET_KEY=your_super_secret_key_here_change_this

# ---- Google Safe Browsing API ----
# Get your key at: https://console.cloud.google.com/
# Enable "Safe Browsing API" in your project
GOOGLE_SAFE_BROWSING_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# ---- MySQL Database Config ----
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=phishing_detector

# ---- App Config ----
FLASK_ENV=development
FLASK_DEBUG=True
